{
  "name": "git-compare-ref-open",
  "displayName": "Git Compare Ref Open",
  "description": "Quickly compare files between Git refs and open diffs in VS Code's native diff editor.",
  "version": "0.0.2",
  "private": true,
  "publisher": "MatteoGauthier",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MatteoGauthier/git-compare-ref-open.git"
  },
  "homepage": "https://github.com/MatteoGauthier/git-compare-ref-open#readme",
  "bugs": {
    "url": "https://github.com/MatteoGauthier/git-compare-ref-open/issues"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-compare-ref-open.compareActiveFileCurrentRight",
        "title": "Compare File with Ref (Current Right)",
        "category": "Git Compare Ref"
      },
      {
        "command": "git-compare-ref-open.compareActiveFileCurrentLeft",
        "title": "Compare File with Ref (Current Left)",
        "category": "Git Compare Ref"
      },
      {
        "command": "git-compare-ref-open.compareActiveFileBetweenRefs",
        "title": "Compare File Between Refs",
        "category": "Git Compare Ref"
      },
      {
        "command": "git-compare-ref-open.browseChangedFiles",
        "title": "Browse Changed Files Between Refs",
        "category": "Git Compare Ref"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "git-compare-ref-open.compareActiveFileCurrentRight",
          "group": "git-compare-ref-open@1",
          "when": "editorTextFocus && resourceScheme == file"
        },
        {
          "command": "git-compare-ref-open.compareActiveFileCurrentLeft",
          "group": "git-compare-ref-open@2",
          "when": "editorTextFocus && resourceScheme == file"
        },
        {
          "command": "git-compare-ref-open.compareActiveFileBetweenRefs",
          "group": "git-compare-ref-open@3",
          "when": "editorTextFocus && resourceScheme == file"
        }
      ]
    },
    "keybindings": [
      {
        "command": "git-compare-ref-open.compareActiveFileCurrentRight",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d",
        "when": "editorTextFocus && resourceScheme == file"
      },
      {
        "command": "git-compare-ref-open.browseChangedFiles",
        "key": "ctrl+alt+shift+d",
        "mac": "cmd+alt+shift+d"
      }
    ],
    "configuration": {
      "title": "Git Compare Ref Open",
      "properties": {
        "gitCompareRefOpen.defaultDiffRange": {
          "type": "string",
          "enum": [
            "threeDot",
            "twoDot"
          ],
          "enumDescriptions": [
            "Compare changes on compareRef since it diverged from baseRef (refA...refB).",
            "Compare changes directly between baseRef and compareRef (refA..refB)."
          ],
          "default": "threeDot",
          "description": "Default diff range when browsing or comparing files between two refs."
        }
      }
    }
  },
  "license": "MIT",
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-extension": "changeset tag && node scripts/publish.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@vscode/vsce": "^3.7.0",
    "ovsx": "^0.10.2",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
